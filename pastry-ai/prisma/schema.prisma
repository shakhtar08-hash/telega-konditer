generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum BotMenuActionType {
  PROMPT
  SCENARIO
  URL
}

model User {
  id                      String                   @id @default(cuid())
  telegramId              String                   @unique
  username                String?
  name                    String?
  plan                    Plan                     @default(FREE)
  credits                 Int                      @default(10)
  promoClaimed            Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  conversations           Conversation[]
  generatedRecipeContexts GeneratedRecipeContext[]
  usage                   Usage[]
  subscription            Subscription?
  payments                Payment[]
  userTariff              UserTariff?
  tokenUsage              TokenUsage[]
  groupMemberships        UserGroupMember[]
}

model UserGroup {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships UserGroupMember[]

  @@unique([name])
}

model UserGroupMember {
  userId      String
  userGroupId String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)

  @@id([userId, userGroupId])
  @@index([userGroupId])
}

model DynamicUserGroup {
  id            String   @id @default(cuid())
  name          String
  description   String?
  status        String   @default("active")
  logicOperator String
  conditionsJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name])
  @@index([status, updatedAt])
}

model TariffPlan {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  tokenAmount  Int
  durationDays Int
  active       Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userTariffs  UserTariff[]
  payments     Payment[]
  subscriptions Subscription[]
}

model UserTariff {
  id              String     @id @default(cuid())
  userId          String     @unique
  tariffPlanId    String
  remainingTokens Int        @default(0)
  startedAt       DateTime   @default(now())
  expiresAt       DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffPlan      TariffPlan @relation(fields: [tariffPlanId], references: [id])
}

model TokenUsage {
  id          String   @id @default(cuid())
  userId      String
  feature     String
  promptSlug  String?
  imagesSent  Int      @default(0)
  tokensSpent Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  tokens         Int?
  model          String?
  cost           Decimal?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Prompt {
  id           String   @id @default(cuid())
  slug         String
  feature      String
  title        String   @default("")
  provider     String   @default("openai")
  systemPrompt String
  userTemplate String
  model        String
  temperature  Float
  active       Boolean  @default(true)
  version      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([slug, version])
  @@index([feature, slug, active])
}

model BotMenuButton {
  id              String            @id @default(cuid())
  label           String
  emoji           String            @default("")
  description     String            @default("")
  instructionText String?
  processingText  String?
  previewImageUrl String?
  fullWidth       Boolean           @default(false)
  actionType      BotMenuActionType @default(PROMPT)
  promptFeature   String?
  promptSlug      String?
  scenarioId      String?
  url             String?
  sortOrder       Int
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  scenario        Scenario?         @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  @@index([active, sortOrder])
  @@index([scenarioId])
}

model BotTextBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramSession {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model ApiSecret {
  id             String   @id @default(cuid())
  key            String   @unique
  encryptedValue String
  valuePreview   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PhotoStyle {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  preview     String?
  userPreview String?
  userText    String?
  provider    String?  @default("openai")
  model       String?  @default("gpt-image-1")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CarouselTemplate {
  id        String   @id @default(cuid())
  name      String
  prompt    String
  slides    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Usage {
  id             String   @id @default(cuid())
  userId         String
  feature        String
  provider       String   @default("")
  model          String?
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  cost           Decimal  @default(0)
  latency        Int      @default(0)
  status         String   @default("success")
  errorMessage   String?
  conversationId String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String      @id @default(cuid())
  userId            String
  provider          String
  invoiceId         String      @unique
  status            String
  amount            Decimal
  currency          String
  providerRawId     String?
  providerPaymentId String?
  providerEventType String?
  tariffPlanId      String?
  paymentMethodId   String?
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffPlan        TariffPlan? @relation(fields: [tariffPlanId], references: [id])

  @@index([userId, status])
}

model FunnelStep {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  text              String
  imagePath         String
  sortOrder         Int
  active            Boolean  @default(true)
  nextButtonText    String   @default("Далее")
  nextAction        String   @default("next")
  buyButtons        Json     @default("[]")
  buyButtonText     String   @default("")
  buyButtonUrl      String?
  offerButtonText   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active, sortOrder])
}

model Subscription {
  id              String      @id @default(cuid())
  userId          String      @unique
  provider        String
  status          String
  tariffPlanId    String?
  paymentMethodId String?
  startedAt       DateTime    @default(now())
  expiresAt       DateTime?
  nextChargeAt    DateTime?
  lastPaidAt      DateTime?
  canceledAt      DateTime?
  lastFailureAt   DateTime?
  failureReason   String?
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffPlan      TariffPlan? @relation(fields: [tariffPlanId], references: [id])
}

model GeneratedRecipeContext {
  id         String   @id @default(cuid())
  userId     String
  recipeText String
  recipeJson Json?
  imageUrl   String?
  source     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TriggerRule {
  id           String    @id @default(cuid())
  name         String
  eventKey     String
  status       String
  delayValue   Int
  delayUnit    String
  deliveryType String    @default("MESSAGE")
  scenarioId   String?
  messageText  String
  imageUrl     String?
  buttons      Json?
  conditions   Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  scenario     Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  @@index([eventKey, status])
  @@index([scenarioId])
}

model Scenario {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      String         @default("draft")
  startStepId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  steps       ScenarioStep[]
  triggers    TriggerRule[]
  botMenuButtons BotMenuButton[]
}

model ScenarioStep {
  id          String           @id @default(cuid())
  scenarioId  String
  name        String
  messageText String
  imageUrl    String?
  sortOrder   Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  scenario    Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  buttons     ScenarioButton[]

  @@index([scenarioId, sortOrder])
}

model ScenarioButton {
  id             String       @id @default(cuid())
  stepId         String
  text           String
  sortOrder      Int
  actionType     String
  actionValue    String?
  transitionMode String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  step           ScenarioStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId, sortOrder])
}

model ScheduledMessage {
  id              String    @id @default(cuid())
  triggerRuleId   String
  triggerEventKey String
  chatId          String
  scenarioId      String?
  scenarioStepId  String?
  text            String
  imageUrl        String?
  buttons         Json?
  triggeredAt     DateTime
  sendAt          DateTime
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([triggerEventKey])
  @@index([triggerRuleId, chatId, sentAt])
  @@index([sentAt, sendAt])
  @@index([scenarioStepId])
}
