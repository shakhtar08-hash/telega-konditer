generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum BotMenuActionType {
  PROMPT
  URL
}

model User {
  id            String         @id @default(cuid())
  telegramId    String         @unique
  username      String?
  name          String?
  plan          Plan           @default(FREE)
  credits       Int            @default(10)
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  usage         Usage[]
  subscription  Subscription?
  payments      Payment[]
  userTariff    UserTariff?
  tokenUsage    TokenUsage[]
}

model TariffPlan {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  tokenAmount  Int
  durationDays Int
  active       Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userTariffs  UserTariff[]
}

model UserTariff {
  id              String     @id @default(cuid())
  userId          String     @unique
  tariffPlanId    String
  remainingTokens Int        @default(0)
  startedAt       DateTime   @default(now())
  expiresAt       DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffPlan      TariffPlan @relation(fields: [tariffPlanId], references: [id])
}

model TokenUsage {
  id          String   @id @default(cuid())
  userId      String
  feature     String
  promptSlug  String?
  imagesSent  Int      @default(0)
  tokensSpent Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  tokens         Int?
  model          String?
  cost           Decimal?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Prompt {
  id           String   @id @default(cuid())
  slug         String
  feature      String
  title        String   @default("")
  provider     String   @default("openai")
  systemPrompt String
  userTemplate String
  model        String
  temperature  Float
  active       Boolean  @default(true)
  version      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([slug, version])
  @@index([feature, slug, active])
}

model BotMenuButton {
  id            String            @id @default(cuid())
  label         String
  emoji         String            @default("")
  description   String            @default("")
  actionType    BotMenuActionType @default(PROMPT)
  promptFeature String?
  promptSlug    String?
  url           String?
  sortOrder     Int
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([active, sortOrder])
}

model BotTextBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramSession {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model ApiSecret {
  id             String   @id @default(cuid())
  key            String   @unique
  encryptedValue String
  valuePreview   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PhotoStyle {
  id          String   @id @default(cuid())
  name        String
  description String
  prompt      String
  preview     String?
  provider    String?  @default("openai")
  model       String?  @default("gpt-image-1")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CarouselTemplate {
  id        String   @id @default(cuid())
  name      String
  prompt    String
  slides    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Usage {
  id           String   @id @default(cuid())
  userId       String
  feature      String
  inputTokens  Int
  outputTokens Int
  cost         Decimal
  latency      Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  invoiceId     String   @unique
  status        String
  amount        Decimal
  currency      String
  providerRawId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model FunnelStep {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  text              String
  imagePath         String
  sortOrder         Int
  active            Boolean  @default(true)
  nextButtonText    String   @default("Далее")
  buyButtonText     String   @default("Купить")
  buyButtonUrl      String?
  offerButtonText   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active, sortOrder])
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  provider  String
  status    String
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TriggerMessage {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  text         String
  delayMinutes Int
  targetPlans  Json
  buttons      Json?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScheduledMessage {
  id          String    @id @default(cuid())
  triggerSlug String
  chatId      String
  text        String
  buttons     Json?
  sendAt      DateTime
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}
