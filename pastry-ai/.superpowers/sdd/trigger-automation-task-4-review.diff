+
+  throw new Error(LEGACY_ACTION_ERROR);
+}
+
+export async function updateTriggerMessage(formData: FormData) {
+  "use server";
+
+  void formData;
+
+  throw new Error(LEGACY_ACTION_ERROR);
+}
+
+export async function deleteTriggerMessage(formData: FormData) {
+  "use server";
+
+  void formData;
+
+  throw new Error(LEGACY_ACTION_ERROR);
+}
